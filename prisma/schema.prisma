generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model TopicGroup {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  topics      Topic[]  @relation("TopicGroups")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Course {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  topics    Topic[]
  chunks    Chunk[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Topic {
  id          String       @id @default(cuid())
  slug        String       @unique
  title       String
  summary     String?
  order       Int
  groups      TopicGroup[] @relation("TopicGroups")
  course      Course       @relation(fields: [courseId], references: [id])
  courseId    String
  blocks      Block[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  embedding   Unsupported("vector(1024)")?
  edgesFrom   TopicEdge[] @relation("EdgeFrom")
  edgesTo     TopicEdge[] @relation("EdgeTo")
}

enum EdgeKind {
  PREREQUISITE_OF
}

model TopicEdge {
  fromId     String
  toId       String
  kind       EdgeKind @default(PREREQUISITE_OF)
  confidence Float
  createdAt  DateTime @default(now())
  from       Topic    @relation("EdgeFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to         Topic    @relation("EdgeTo",   fields: [toId],   references: [id], onDelete: Cascade)

  @@id([fromId, toId, kind])
  @@index([toId])
  @@index([fromId])
}

enum BlockSource {
  local
  web
  manual
  generated
}

model Block {
  id                   String      @id @default(cuid())
  type                 BlockType
  content              Json
  order                Int
  source               BlockSource @default(generated)
  citation             String?
  manually_edited      Boolean     @default(false)
  generation_metadata  Json?
  group_id             String?
  topic                Topic       @relation(fields: [topicId], references: [id])
  topicId              String
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  @@unique([topicId, order])
  @@index([group_id])
  @@index([topicId, group_id])
}

enum BlockType {
  paragraph
  heading
  bulletListItem
  numberedListItem
  codeBlock
  math
  plot
  callout
  image
}

model Chunk {
  id          String   @id @default(cuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  content     String   @db.Text
  contentHash String   // sha256 hex of content, for change detection

  sourcePath  String   // relative path within course source dir
  sourceType  String   // pdf, docx, xlsx, pptx, ipynb, code, markdown, txt
  chunkIndex  Int      // position within source file
  pageNumber  Int?     // optional, primarily for PDF chunks
  sectionPath String?  // optional, hierarchical location ("Ch 14 > 8")
  tokenCount  Int?     // optional, for cost reporting

  embedding   Unsupported("vector(1024)")?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([courseId, sourcePath, chunkIndex])
  @@index([courseId])
  @@index([contentHash])
}

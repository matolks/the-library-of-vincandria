generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model TopicGroup {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  topics      Topic[]  @relation("TopicGroups")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Course {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  topics    Topic[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Topic {
  id          String       @id @default(cuid())
  slug        String       @unique
  title       String
  summary     String?
  order       Int
  groups      TopicGroup[] @relation("TopicGroups")
  course      Course       @relation(fields: [courseId], references: [id])
  courseId    String
  blocks      Block[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  embedding   Unsupported("vector(1024)")?
  edgesFrom   TopicEdge[] @relation("EdgeFrom")
  edgesTo     TopicEdge[] @relation("EdgeTo")
}

enum EdgeKind {
  PREREQUISITE_OF
}

model TopicEdge {
  fromId     String
  toId       String
  kind       EdgeKind @default(PREREQUISITE_OF)
  confidence Float
  createdAt  DateTime @default(now())
  from       Topic    @relation("EdgeFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to         Topic    @relation("EdgeTo",   fields: [toId],   references: [id], onDelete: Cascade)

  @@id([fromId, toId, kind])
  @@index([toId])
  @@index([fromId])
}

model Block {
  id              String      @id @default(cuid())
  type            String
  content         String
  order           Int
  language        String?
  source          BlockSource @default(generated)
  citation        String?
  manually_edited Boolean     @default(false)
  topic           Topic       @relation(fields: [topicId], references: [id])
  topicId         String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  @@unique([topicId, order])
}

enum BlockSource {
  local
  web
  manual
  generated
}